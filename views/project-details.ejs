<article class="project-detail">
    <h1><%= project.title %></h1>
    <p class="tagline"><%= project.tagline %></p>
    
    <% if (project.categoryId) { %>
        <p class="project-category">
            <strong>Category:</strong> 
            <a href="/projects/category/<%= project.categoryId.slug %>">
                <%= project.categoryId.name %>
            </a>
        </p>
    <% } %>
    
    <div class="project-images">
        <% project.images.forEach(image => { %>
            <img src="<%= image.path %>" alt="<%= image.alt %>" class="project-screenshot">
        <% }); %>
    </div>
    
    <section class="project-description">
        <h2>About This Project</h2>
        <p><%= project.description %></p>
    </section>
    
    <section class="project-tech">
        <h3>Technologies Used</h3>
        <div class="stack">
            <% project.stack.forEach(tech => { %>
                <span class="badge"><%= tech %></span>
            <% }); %>
        </div>
    </section>
    
    <section class="project-tags">
        <h3>Tags</h3>
        <div class="tags">
            <% project.tags.forEach(tag => { %>
                <a href="/projects?tag=<%= tag.name %>" class="tag"><%= tag.name %></a>
            <% }); %>
        </div>
    </section>
    
    <section class="project-dates">
        <p><strong>Created:</strong> <%= project.dates.created %></p>
        <p><strong>Last Updated:</strong> <%= project.dates.updated %></p>
    </section>
    
    <a href="/projects" class="btn">← Back to Projects</a>
</article>