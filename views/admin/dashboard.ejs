<h1>Admin Dashboard</h1>

<div class="admin-stats">
    <div class="stat-card">
        <h3>Projects</h3>
        <p class="stat-number"><%= stats.activeProjects %> / <%= stats.totalProjects %></p>
        <p class="stat-label">Active / Total</p>
        <a href="/admin/projects" class="btn">Manage Projects</a>
    </div>

    <div class="stat-card">
        <h3>Categories</h3>
        <p class="stat-number"><%= stats.totalCategories %></p>
        <p class="stat-label">Total Categories</p>
        <a href="/admin/categories" class="btn">Manage Categories</a>
    </div>

    <div class="stat-card">
        <h3>Contacts</h3>
        <p class="stat-number"><%= stats.unreadContacts %> / <%= stats.totalContacts %></p>
        <p class="stat-label">Unread / Total</p>
        <a href="/admin/contacts" class="btn">Manage Contacts</a>
    </div>
</div>

<div class="admin-links">
    <h2>Quick Links</h2>
    <ul>
        <li><a href="/admin/projects/new">Create New Project</a></li>
        <li><a href="/admin/categories/new">Create New Category</a></li>
        <li><a href="/">View Public Site</a></li>
    </ul>
</div>