<h1><%= project ? 'Edit' : 'Create' %> Project</h1>

<p><a href="/admin/projects">← Back to Projects</a></p>

<% if (typeof error !== 'undefined') { %>
    <div class="error-message"><%= error %></div>
<% } %>

<form method="POST" action="<%= project ? `/admin/projects/${project._id}` : '/admin/projects' %>" class="admin-form">
    <div class="form-group">
        <label for="title">Title *</label>
        <input 
            type="text" 
            id="title" 
            name="title" 
            value="<%= project ? project.title : '' %>" 
            required
        >
    </div>

    <div class="form-group">
        <label for="slug">Slug * (URL-safe, lowercase)</label>
        <input 
            type="text" 
            id="slug" 
            name="slug" 
            value="<%= project ? project.slug : '' %>" 
            pattern="[a-z0-9-]+"
            required
        >
        <small>Example: my-awesome-project</small>
    </div>

    <div class="form-group">
        <label for="tagline">Tagline</label>
        <input 
            type="text" 
            id="tagline" 
            name="tagline" 
            value="<%= project ? project.tagline : '' %>"
        >
    </div>

    <div class="form-group">
        <label for="description">Description *</label>
        <textarea 
            id="description" 
            name="description" 
            rows="5"
            required
        ><%= project ? project.description : '' %></textarea>
    </div>

    <div class="form-group">
        <label for="categoryId">Category *</label>
        <select id="categoryId" name="categoryId" required>
            <option value="">-- Select Category --</option>
            <% categories.forEach(category => { %>
                <option 
                    value="<%= category._id %>"
                    <%= project && project.categoryId && project.categoryId.toString() === category._id.toString() ? 'selected' : '' %>
                >
                    <%= category.name %>
                </option>
            <% }); %>
        </select>
    </div>

    <div class="form-group">
        <label for="tags">Tags (comma-separated) *</label>
        <input 
            type="text" 
            id="tags" 
            name="tags" 
            value="<%= project ? project.tagsString : '' %>"
            placeholder="react, node, api"
        >
        <small>Example: dom, events, game-loop, state</small>
    </div>

    <div class="form-group">
        <label for="stack">Tech Stack (comma-separated)</label>
        <input 
            type="text" 
            id="stack" 
            name="stack" 
            value="<%= project ? project.stackString : '' %>"
            placeholder="html, css, javascript"
        >
    </div>

    <div class="form-group">
        <label for="isActive">Status *</label>
        <select id="isActive" name="isActive" required>
            <option value="true" <%= project && project.isActive ? 'selected' : '' %>>Active (Public)</option>
            <option value="false" <%= project && !project.isActive ? 'selected' : '' %>>Inactive (Hidden)</option>
        </select>
    </div>

    <button type="submit" class="btn">
        <%= project ? 'Update' : 'Create' %> Project
    </button>
</form>