<h1><%= category ? 'Edit' : 'Create' %> Category</h1>

<p><a href="/admin/categories">← Back to Categories</a></p>

<% if (typeof error !== 'undefined') { %>
    <div class="error-message"><%= error %></div>
<% } %>

<form method="POST" action="<%= category ? `/admin/categories/${category._id}` : '/admin/categories' %>" class="admin-form">
    <div class="form-group">
        <label for="name">Name *</label>
        <input 
            type="text" 
            id="name" 
            name="name" 
            value="<%= category ? category.name : '' %>" 
            required
        >
    </div>

    <div class="form-group">
        <label for="slug">Slug * (URL-safe, lowercase)</label>
        <input 
            type="text" 
            id="slug" 
            name="slug" 
            value="<%= category ? category.slug : '' %>" 
            pattern="[a-z0-9-]+"
            required
        >
        <small>Example: web-development</small>
    </div>

    <div class="form-group">
        <label for="description">Description</label>
        <textarea 
            id="description" 
            name="description" 
            rows="3"
        ><%= category ? category.description : '' %></textarea>
    </div>

    <button type="submit" class="btn">
        <%= category ? 'Update' : 'Create' %> Category
    </button>
</form>