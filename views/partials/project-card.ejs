<article class="project-card">
    <% 
    // Find featured image, or fall back to first image
    const featuredImage = project.images && project.images.length > 0 
        ? project.images.find(img => img.isFeatured) || project.images[0]
        : null;
    %>
    
    <% if (featuredImage) { %>
        <img src="<%= featuredImage.path %>" alt="<%= featuredImage.alt %>" class="project-image">
    <% } %>
    
    <div class="project-info">
        <h3><%= project.title %></h3>
        
        <% if (project.tagline) { %>
            <p class="tagline"><%= project.tagline %></p>
        <% } %>
        
        <% if (project.categoryId) { %>
            <p class="category-badge">
                <a href="/projects/category/<%= project.categoryId.slug %>">
                    <%= project.categoryId.name %>
                </a>
            </p>
        <% } %>
        
        <% if (project.stack && project.stack.length > 0) { %>
            <div class="stack">
                <% project.stack.forEach(tech => { %>
                    <span class="badge"><%= tech %></span>
                <% }); %>
            </div>
        <% } %>
        
        <a href="/projects/<%= project.slug %>" class="btn">View Project</a>
    </div>
</article>