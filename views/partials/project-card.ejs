<article class="project-card">
    <% const coverImage = project.images && project.images.length > 0 ? project.images.find(img => img.type === 'cover') : null; %>
    <% if (coverImage) { %>
        <img src="<%= coverImage.path %>" alt="<%= coverImage.alt %>" class="project-image">
    <% } %>
    
    <div class="project-info">
        <h3><%= project.title %></h3>
        <p class="tagline"><%= project.tagline %></p>
        
        <% if (project.categoryId) { %>
            <p class="category-badge">
                <a href="/projects/category/<%= project.categoryId.slug %>">
                    <%= project.categoryId.name %>
                </a>
            </p>
        <% } %>
        
        <div class="stack">
            <% project.stack.forEach(tech => { %>
                <span class="badge"><%= tech %></span>
            <% }); %>
        </div>
        
        <a href="/projects/<%= project.slug %>" class="btn">View Project</a>
    </div>
</article>